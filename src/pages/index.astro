---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Hero from '../components/Hero.astro';
import PostPreview from '../components/PostPreview.astro';
import ProjectPreview from '../components/ProjectPreview.astro';
import siteConfig from '../data/site-config';
import { sortItemsByDateDesc } from '../utils/data-utils';
import SongkickWidget from '../components/SongkickWidget.astro';
import MerchButton1 from '../components/MerchButton-Hellhound-TShirt.astro';
import MerchButton2 from '../components/MerchButton-Wolf-Hoodie.astro';
import MerchButton3 from '../components/MerchButton-Wolf-TShirt.astro';
import MerchButton4 from '../components/MerchButton-Hellhound-TShirt-CreamWhite.astro';
import Subscribe from '../components/Subscribe.astro';

const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);
const featuredPosts = posts.filter(({ data }) => data.isFeatured);

const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
const featuredProjects = projects.filter(({ data }) => data.isFeatured);
---

<BaseLayout description={siteConfig.description} image={siteConfig.image}>
    <Hero />
    {
        featuredProjects?.length > 0 && (
            <div class="mb-16 sm:mb-24">
                <h2 class="mb-12 text-xl font-serif italic sm:mb-16 sm:text-2xl">Releases</h2>
                {featuredProjects.map((project) => (
                    <ProjectPreview project={project} class="mb-10 sm:mb-12" headingLevel="h3" />
                ))}
                <div class="mt-12 sm:mt-16">
                    <Button href="/music">View All Releases</Button>
                </div>
            </div>
        )
    }
    {
        (
            <div class="mb-16 sm:mb-24">
                <h2 class="mb-12 text-xl font-serif italic sm:mb-16 sm:text-2xl">Upcoming Dates</h2>
                <SongkickWidget />
            </div>
        )
    }
    {
        (
            <div class="mb-16 sm:mb-24">
                <h2 class="mb-12 text-xl font-serif italic sm:mb-16 sm:text-2xl">
                    <a
                        href="https://store.chorosia.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:underline hover:underline-offset-2 hover:decoration-1"
                    >
                        Visit our Merch Store
                    </a>
                </h2>
                <div class="merch">
                    <MerchButton1 />
                    <MerchButton2 />
                    <MerchButton3 />
                    <MerchButton4 />
                </div>
                <div class="mt-12 sm:mt-16">
                    <Button href="https://store.chorosia.com" target="_blank" rel="noopener noreferrer">
                        See More in Store
                    </Button>
                </div>
            </div>
        )
    }
    {
        featuredPosts?.length > 0 && (
            <div class="mb-16 sm:mb-24">
                <h2 class="mb-12 text-xl font-serif italic sm:mb-16 sm:text-2xl">News and Blog</h2>
                {featuredPosts.map((post) => (
                    <PostPreview post={post} class="mb-10 sm:mb-12" headingLevel="h3" />
                ))}
                <div class="mt-12 sm:mt-16">
                    <Button href="/blog">View More</Button>
                </div>
            </div>
        )
    }
    <Subscribe />
</BaseLayout>
